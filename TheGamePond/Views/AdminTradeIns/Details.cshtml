@model TradeInRequest

@{
    ViewData["Title"] = $"Trade-In {Model.RequestNumber}";
}

<section class="admin-shell">
    <div class="container">
        <div class="admin-heading">
            <div>
                <p class="eyebrow">Trade-in detail</p>
                <h1>@Model.RequestNumber</h1>
            </div>
            <a class="btn btn-outline-pond" asp-action="Index">Trade-ins</a>
        </div>

        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-success" role="alert">@statusMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="admin-card">
                    <h2 class="admin-subheading">Customer</h2>
                    <dl class="detail-list">
                        <dt>Name</dt>
                        <dd>@Model.CustomerName</dd>
                        <dt>Email</dt>
                        <dd>@Model.CustomerEmail</dd>
                        <dt>Phone</dt>
                        <dd>@(Model.CustomerPhone ?? "Not provided")</dd>
                        <dt>Preferred contact</dt>
                        <dd>@Model.PreferredContactMethod</dd>
                        <dt>Status</dt>
                        <dd>@Model.Status</dd>
                    </dl>
                </div>

                <div class="admin-card mt-4">
                    <h2 class="admin-subheading">Review</h2>
                    <form asp-action="UpdateStatus" asp-route-requestNumber="@Model.RequestNumber" method="post">
                        <input type="hidden" name="RequestNumber" value="@Model.RequestNumber" />
                        <div class="mb-3">
                            <label class="form-label" for="Status">Status</label>
                            <select class="form-select" id="Status" name="Status" asp-items="Html.GetEnumSelectList<TradeInRequestStatus>()"></select>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="EstimatedOfferLow">Offer low</label>
                                <input class="form-control" id="EstimatedOfferLow" name="EstimatedOfferLow" value="@Model.EstimatedOfferLow" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="EstimatedOfferHigh">Offer high</label>
                                <input class="form-control" id="EstimatedOfferHigh" name="EstimatedOfferHigh" value="@Model.EstimatedOfferHigh" />
                            </div>
                        </div>
                        <div class="mt-3 mb-3">
                            <label class="form-label" for="StaffNotes">Staff notes</label>
                            <textarea class="form-control" id="StaffNotes" name="StaffNotes" rows="5">@Model.StaffNotes</textarea>
                        </div>
                        <button class="btn btn-pond w-100" type="submit">Save review</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="admin-card">
                    <h2 class="admin-subheading">Items</h2>
                    <div class="admin-table-shell">
                        <table class="table admin-table align-middle">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Platform</th>
                                    <th>Condition</th>
                                    <th>Qty</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td><strong>@item.ItemName</strong></td>
                                        <td>@(item.Platform ?? "-")</td>
                                        <td>@(item.Condition ?? "-")</td>
                                        <td>@item.Quantity</td>
                                        <td>@(item.Notes ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="admin-card mt-4">
                    <h2 class="admin-subheading">Customer notes</h2>
                    <p class="detail-copy">@(Model.CustomerNotes ?? "No customer notes provided.")</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.getElementById("Status").value = "@((int)Model.Status)";
</script>
