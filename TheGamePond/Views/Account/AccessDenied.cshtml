@{
    ViewData["Title"] = "Access Denied";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="auth-panel text-center">
                    <img class="auth-logo" src="~/images/brand/the-game-pond-logo.png" alt="The Game Pond logo" />
                    <h1>Access Denied</h1>
                    <p>Your account does not have permission to view this area.</p>
                    <a class="btn btn-outline-pond" asp-controller="Home" asp-action="Index">Back home</a>
                </div>
            </div>
        </div>
    </div>
</section>
