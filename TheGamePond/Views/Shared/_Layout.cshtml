<!DOCTYPE html>
@{
    var title = ViewData["Title"] as string ?? "The Game Pond";
    var pageTitle = title == "The Game Pond" ? title : $"{title} - The Game Pond";
    var metaDescription = ViewData["MetaDescription"] as string
        ?? "Shop games, trading cards, retro consoles, accessories, collectibles, and trade-ins at The Game Pond.";
    var canonicalUrl = ViewData["CanonicalUrl"] as string;
    var robots = ViewData["Robots"] as string;
    var ogTitle = ViewData["OgTitle"] as string ?? pageTitle;
    var ogDescription = ViewData["OgDescription"] as string ?? metaDescription;
    var ogImage = ViewData["OgImage"] as string;
    var absoluteOgImage = string.IsNullOrWhiteSpace(ogImage)
        ? null
        : ogImage.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? ogImage
            : $"{Context.Request.Scheme}://{Context.Request.Host}{ogImage}";
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <meta name="description" content="@metaDescription" />
    @if (!string.IsNullOrWhiteSpace(robots))
    {
        <meta name="robots" content="@robots" />
    }
    @if (!string.IsNullOrWhiteSpace(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
    }
    <meta property="og:site_name" content="The Game Pond" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:type" content="website" />
    @if (!string.IsNullOrWhiteSpace(absoluteOgImage))
    {
        <meta property="og:image" content="@absoluteOgImage" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TheGamePond.styles.css" asp-append-version="true" />
</head>
<body class="pond-app">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark pond-navbar">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img class="brand-logo" src="~/images/brand/the-game-pond-logo.png" alt="The Game Pond logo" />
                    <span>The Game Pond</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-end">
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Shop" asp-action="Index">Shop</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Orders" asp-action="Lookup">Order Lookup</a>
                        </li>
                        <li class="nav-item">
                            @await Component.InvokeAsync("CartNav")
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TradeIns" asp-action="Create">Trade-In</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminProducts" asp-action="Index">Products</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminOrders" asp-action="Index">Orders</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminTradeIns" asp-action="Index">Trade-Ins</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="nav-logout">
                                    <button type="submit" class="btn btn-outline-pond btn-sm">Sign out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-pond btn-sm" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="site-frame">
        <main role="main" class="site-main pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer pond-footer">
        <div class="container">
            &copy; 2026 - The Game Pond - Collect. Play. Repeat.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
