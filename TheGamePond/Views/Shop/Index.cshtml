@model ShopIndexViewModel

@{
    ViewData["Title"] = "Shop";
    ViewData["MetaDescription"] = "Browse The Game Pond inventory for video games, consoles, trading cards, accessories, collectibles, and retro finds.";
    ViewData["CanonicalUrl"] = Url.Action("Index", "Shop", null, Context.Request.Scheme);
    ViewData["OgTitle"] = "Shop The Pond - The Game Pond";
    ViewData["OgImage"] = Url.Content("~/images/brand/the-game-pond-logo.png");
}

<section class="shop-shell">
    <div class="container">
        <div class="shop-heading">
            <div>
                <p class="eyebrow">Games - TCG - Retro - Collectibles</p>
                <h1>Shop The Pond</h1>
            </div>
        </div>

        <form method="get" class="shop-filter-bar">
            <div>
                <label asp-for="Search" class="form-label">Search</label>
                <input asp-for="Search" class="form-control" placeholder="Pokemon, Switch, Zelda, controller" />
            </div>
            <div>
                <label asp-for="Category" class="form-label">Category</label>
                <select asp-for="Category" class="form-select">
                    <option value="">All categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Slug">@category.Name</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Sort" class="form-label">Sort</label>
                <select asp-for="Sort" class="form-select">
                    <option value="newest">Newest</option>
                    <option value="name">Name A-Z</option>
                    <option value="price-low">Price low to high</option>
                    <option value="price-high">Price high to low</option>
                </select>
            </div>
            <div class="shop-filter-actions">
                <button type="submit" class="btn btn-outline-pond">Filter</button>
                <a class="btn btn-link" asp-action="Index">Clear</a>
            </div>
        </form>

        @if (Model.HasActiveFilters)
        {
            <div class="shop-active-filters" aria-label="Active filters">
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <span>Search: @Model.Search</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SelectedCategoryName))
                {
                    <span>Category: @Model.SelectedCategoryName</span>
                }
                @if (Model.Sort != "newest")
                {
                    <span>Sort: @(Model.Sort == "name" ? "Name A-Z" : Model.Sort == "price-low" ? "Price low to high" : "Price high to low")</span>
                }
            </div>
        }

        @if (Model.Products.Count == 0)
        {
            <div class="shop-empty">
                <h2>No products found</h2>
                <p>Check back soon for new drops.</p>
            </div>
        }
        else
        {
            <div class="product-grid">
                @foreach (var product in Model.Products)
                {
                    <article class="shop-product-card">
                        <a class="shop-product-image"
                           asp-action="Details"
                           asp-route-slug="@product.Slug"
                           asp-route-search="@Model.Search"
                           asp-route-category="@Model.Category"
                           asp-route-sort="@Model.Sort">
                            @if (product.PrimaryImagePath is not null)
                            {
                                <img src="@product.PrimaryImagePath" alt="@product.PrimaryImageAltText" />
                            }
                            else
                            {
                                <span>TGP</span>
                            }
                        </a>
                        <div class="shop-product-body">
                            <div class="shop-product-meta">
                                <span>@product.CategoryName</span>
                                <span>@product.Condition</span>
                            </div>
                            <h2>
                                <a asp-action="Details"
                                   asp-route-slug="@product.Slug"
                                   asp-route-search="@Model.Search"
                                   asp-route-category="@Model.Category"
                                   asp-route-sort="@Model.Sort">@product.Name</a>
                            </h2>
                            <p>@product.Platform</p>
                            <div class="shop-product-footer">
                                <strong>@product.SalePrice.ToString("C")</strong>
                                @if (product.IsInStock)
                                {
                                    <span class="stock-pill">@product.QuantityOnHand in stock</span>
                                }
                                else
                                {
                                    <span class="stock-pill stock-pill-empty">Sold out</span>
                                }
                            </div>
                            <div class="shop-product-actions">
                                <a class="btn btn-outline-pond"
                                   asp-action="Details"
                                   asp-route-slug="@product.Slug"
                                   asp-route-search="@Model.Search"
                                   asp-route-category="@Model.Category"
                                   asp-route-sort="@Model.Sort">Details</a>
                                @if (product.IsInStock)
                                {
                                    <form asp-controller="Cart" asp-action="Add" asp-route-slug="@product.Slug" method="post">
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-pond">Add</button>
                                    </form>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-pond" disabled>Sold out</button>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
