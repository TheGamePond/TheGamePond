@model ProductFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="7"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Platform" class="form-label"></label>
                <input asp-for="Platform" class="form-control" placeholder="Switch, PS5, Xbox, TCG" />
                <span asp-validation-for="Platform" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Franchise" class="form-label"></label>
                <input asp-for="Franchise" class="form-control" placeholder="Pokemon, Zelda, Mario" />
                <span asp-validation-for="Franchise" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Sku" class="form-label"></label>
                <input asp-for="Sku" class="form-control" />
                <span asp-validation-for="Sku" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Barcode" class="form-label"></label>
                <input asp-for="Barcode" class="form-control" />
                <span asp-validation-for="Barcode" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" asp-items="@(ViewBag.CategoryOptions as IEnumerable<SelectListItem>)" class="form-select">
                    <option value="">Choose category</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Condition" class="form-label"></label>
                <select asp-for="Condition" asp-items="Html.GetEnumSelectList<ProductCondition>()" class="form-select"></select>
                <span asp-validation-for="Condition" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<ProductStatus>()" class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CostPrice" class="form-label"></label>
                <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="CostPrice" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="SalePrice" class="form-label"></label>
                <input asp-for="SalePrice" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="SalePrice" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="QuantityOnHand" class="form-label"></label>
                <input asp-for="QuantityOnHand" class="form-control" type="number" min="0" />
                <span asp-validation-for="QuantityOnHand" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LowStockThreshold" class="form-label"></label>
                <input asp-for="LowStockThreshold" class="form-control" type="number" min="0" />
                <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="LocationCode" class="form-label"></label>
                <input asp-for="LocationCode" class="form-control" placeholder="Shelf, bin, case, or back room" />
                <span asp-validation-for="LocationCode" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="ImageUpload" class="form-label"></label>
                <input asp-for="ImageUpload" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <span asp-validation-for="ImageUpload" class="text-danger"></span>
            </div>
        </div>

        @if (Model.ExistingImages.Count > 0)
        {
            <div class="existing-images">
                @foreach (var image in Model.ExistingImages)
                {
                    <div>
                        <img src="@image.ImagePath" alt="@image.AltText" />
                        @if (image.IsPrimary)
                        {
                            <span>Primary</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="product-form-actions">
    <button type="submit" class="btn btn-pond">@ViewData["SubmitLabel"]</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</div>
