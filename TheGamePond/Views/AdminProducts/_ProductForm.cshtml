@model TheGamePond.Models.Admin.ProductFormViewModel

<form method="post" enctype="multipart/form-data" class="admin-card">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Id" type="hidden" />
    <input asp-for="ExistingImagePath" type="hidden" />

    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="ProductCategoryId" class="form-label"></label>
            <select asp-for="ProductCategoryId" asp-items="Model.Categories" class="form-select">
                <option value="">Choose category</option>
            </select>
            <span asp-validation-for="ProductCategoryId" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Sku" class="form-label"></label>
            <input asp-for="Sku" class="form-control" />
            <span asp-validation-for="Sku" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Barcode" class="form-label"></label>
            <input asp-for="Barcode" class="form-control" />
            <span asp-validation-for="Barcode" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Platform" class="form-label"></label>
            <input asp-for="Platform" class="form-control" placeholder="Nintendo, PlayStation, Pokemon..." />
            <span asp-validation-for="Platform" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Condition" class="form-label"></label>
            <input asp-for="Condition" class="form-control" placeholder="New, Used, Sealed..." />
            <span asp-validation-for="Condition" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="CostPrice" class="form-label"></label>
            <input asp-for="CostPrice" class="form-control" />
            <span asp-validation-for="CostPrice" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SalePrice" class="form-label"></label>
            <input asp-for="SalePrice" class="form-control" />
            <span asp-validation-for="SalePrice" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="QuantityOnHand" class="form-label"></label>
            <input asp-for="QuantityOnHand" class="form-control" />
            <span asp-validation-for="QuantityOnHand" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LowStockThreshold" class="form-label"></label>
            <input asp-for="LowStockThreshold" class="form-control" />
            <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-md-8">
            <label asp-for="ImageUpload" class="form-label"></label>
            <input asp-for="ImageUpload" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="ImageUpload" class="text-danger"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <label class="form-check admin-check">
                <input asp-for="IsActive" class="form-check-input" />
                <span class="form-check-label">Visible in catalog</span>
            </label>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
        {
            <div class="col-12">
                <img class="product-preview" src="@Model.ExistingImagePath" alt="@Model.Name" />
            </div>
        }
    </div>

    <div class="admin-form-actions">
        <button class="btn btn-pond" type="submit">Save product</button>
        <a class="btn btn-outline-pond" asp-action="Index">Cancel</a>
    </div>
</form>
