@model IReadOnlyList<TheGamePond.Models.Catalog.Product>

@{
    ViewData["Title"] = "Products";
    var search = ViewData["Search"] as string;
    var lowStock = ViewData["LowStock"] as bool? ?? false;
}

<section class="admin-shell">
    <div class="container">
        <div class="admin-heading">
            <div>
                <p class="eyebrow">Catalog operations</p>
                <h1>Products</h1>
            </div>
            <a class="btn btn-pond" asp-action="Create">Add product</a>
        </div>

        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-success" role="alert">@statusMessage</div>
        }

        <form class="admin-filter" method="get">
            <input class="form-control" type="search" name="search" value="@search" placeholder="Search name, SKU, or barcode" />
            <label class="form-check">
                <input class="form-check-input" type="checkbox" name="lowStock" value="true" checked="@lowStock" />
                <span class="form-check-label">Low stock only</span>
            </label>
            <button class="btn btn-outline-pond" type="submit">Filter</button>
        </form>

        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>SKU</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="empty-state">No products match the current filter.</td>
                        </tr>
                    }
                    @foreach (var product in Model)
                    {
                        var image = product.Images.FirstOrDefault(image => image.IsPrimary) ?? product.Images.FirstOrDefault();
                        var quantity = product.InventoryItem?.QuantityOnHand ?? 0;
                        var threshold = product.InventoryItem?.LowStockThreshold ?? 0;
                        var isLowStock = quantity <= threshold;

                        <tr>
                            <td>
                                <div class="product-cell">
                                    @if (image is not null)
                                    {
                                        <img src="@image.FilePath" alt="@image.AltText" />
                                    }
                                    else
                                    {
                                        <span class="product-thumb-placeholder">TGP</span>
                                    }
                                    <div>
                                        <strong>@product.Name</strong>
                                        <span>@product.Platform / @product.Condition</span>
                                    </div>
                                </div>
                            </td>
                            <td>@product.Category?.Name</td>
                            <td>@product.Sku</td>
                            <td>@product.SalePrice.ToString("C")</td>
                            <td>
                                <span class="stock-pill @(isLowStock ? "stock-low" : "stock-ok")">@quantity</span>
                            </td>
                            <td>@(product.IsActive ? "Active" : "Hidden")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-pond" asp-action="Details" asp-route-id="@product.Id">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
