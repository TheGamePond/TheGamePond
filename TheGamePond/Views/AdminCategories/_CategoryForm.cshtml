@model TheGamePond.Models.Catalog.ProductCategory

<form method="post" class="admin-card">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Id" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />

    <div class="row g-3">
        <div class="col-md-7">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-5">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control" />
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SortOrder" class="form-label"></label>
            <input asp-for="SortOrder" class="form-control" type="number" />
            <span asp-validation-for="SortOrder" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-check admin-check">
                <input asp-for="IsActive" class="form-check-input" />
                <span class="form-check-label">Active category</span>
            </label>
        </div>
    </div>

    <div class="admin-form-actions">
        <button class="btn btn-pond" type="submit">Save category</button>
        <a class="btn btn-outline-pond" asp-action="Index">Cancel</a>
    </div>
</form>
