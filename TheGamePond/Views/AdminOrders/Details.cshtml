@model Order

@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    var allowedNextStatuses = TheGamePond.Controllers.AdminOrdersController.GetAllowedNextStatuses(Model.Status);
}

<section class="admin-shell">
    <div class="container">
        <div class="admin-heading">
            <div>
                <p class="eyebrow">Order detail</p>
                <h1>@Model.OrderNumber</h1>
            </div>
            <a class="btn btn-outline-pond" asp-action="Index">Orders</a>
        </div>

        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-success" role="alert">@statusMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="admin-card">
                    <h2 class="admin-subheading">Customer</h2>
                    <dl class="detail-list">
                        <dt>Name</dt>
                        <dd>@Model.CustomerName</dd>
                        <dt>Email</dt>
                        <dd>@Model.CustomerEmail</dd>
                        <dt>Phone</dt>
                        <dd>@(Model.CustomerPhone ?? "Not provided")</dd>
                        <dt>Status</dt>
                        <dd>@Model.Status</dd>
                        <dt>Payment</dt>
                        <dd>@Model.PaymentStatus</dd>
                        <dt>Tracking</dt>
                        <dd>@(Model.TrackingNumber ?? "Not set")</dd>
                    </dl>
                </div>

                <div class="admin-card mt-4">
                    <h2 class="admin-subheading">Shipping</h2>
                    <p class="detail-copy">
                        @Model.ShippingAddressLine1<br />
                        @if (!string.IsNullOrWhiteSpace(Model.ShippingAddressLine2))
                        {
                            @Model.ShippingAddressLine2<br />
                        }
                        @Model.ShippingCity, @Model.ShippingState @Model.ShippingPostalCode<br />
                        @Model.ShippingCountry
                    </p>
                </div>

                <form asp-action="UpdateFulfillment" asp-route-orderNumber="@Model.OrderNumber" method="post">
                    <input type="hidden" name="OrderNumber" value="@Model.OrderNumber" />

                    <div class="admin-card mt-4">
                        <h2 class="admin-subheading">Fulfillment</h2>
                        <div class="mb-3">
                            <label class="form-label" for="TrackingNumber">Tracking number</label>
                            <input class="form-control" id="TrackingNumber" name="TrackingNumber" value="@Model.TrackingNumber" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="StaffNotes">Staff notes</label>
                            <textarea class="form-control" id="StaffNotes" name="StaffNotes" rows="4">@Model.StaffNotes</textarea>
                        </div>
                        <button class="btn btn-outline-pond w-100" type="submit">Save fulfillment details</button>
                    </div>

                    <div class="admin-card mt-4">
                        <h2 class="admin-subheading">Status transitions</h2>
                        @if (!allowedNextStatuses.Any())
                        {
                            <p class="detail-copy">No further transitions are available for this order.</p>
                        }
                        else
                        {
                            <div class="order-transition-list">
                                @foreach (var nextStatus in allowedNextStatuses)
                                {
                                    <button class="btn @(nextStatus is OrderStatus.Cancelled or OrderStatus.Refunded ? "btn-outline-danger" : "btn-pond") w-100"
                                            type="submit"
                                            name="NextStatus"
                                            value="@((int)nextStatus)"
                                            formaction="@Url.Action("UpdateStatus", new { orderNumber = Model.OrderNumber })"
                                            formmethod="post">
                                        Move to @nextStatus
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </form>
            </div>

            <div class="col-lg-8">
                <div class="admin-card">
                    <h2 class="admin-subheading">Items</h2>
                    <div class="admin-table-shell">
                        <table class="table admin-table align-middle">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Qty</th>
                                    <th>Unit</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.ProductName</strong>
                                            <span class="table-subtitle d-block">SKU @item.Sku</span>
                                        </td>
                                        <td>@item.Quantity</td>
                                        <td>@item.UnitPrice.ToString("C")</td>
                                        <td class="text-end">@item.LineTotal.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="cart-summary-total">
                        <span>Total</span>
                        <strong>@Model.Total.ToString("C")</strong>
                    </div>
                </div>

                <div class="admin-card mt-4">
                    <h2 class="admin-subheading">Status history</h2>
                    <div class="admin-table-shell">
                        <table class="table admin-table align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.StatusHistory.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="empty-state">No status changes yet.</td>
                                    </tr>
                                }
                                @foreach (var history in Model.StatusHistory)
                                {
                                    <tr>
                                        <td>@history.CreatedAt.LocalDateTime.ToString("g")</td>
                                        <td>@history.FromStatus</td>
                                        <td>@history.ToStatus</td>
                                        <td>@(history.Notes ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="admin-card mt-4">
                    <h2 class="admin-subheading">Payment events</h2>
                    <div class="admin-table-shell">
                        <table class="table admin-table align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Provider</th>
                                    <th>Event</th>
                                    <th>Processed</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var paymentEvent in Model.PaymentEvents)
                                {
                                    <tr>
                                        <td>@paymentEvent.CreatedAt.LocalDateTime.ToString("g")</td>
                                        <td>@paymentEvent.Provider</td>
                                        <td>@paymentEvent.EventType</td>
                                        <td>@(paymentEvent.WasProcessed ? "Yes" : "No")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
