@{
    ViewData["Title"] = "Collect. Play. Repeat.";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="eyebrow">Gaming - TCG - Retro - Collectibles</p>
                <h1>Enter The Pond</h1>
                <p class="hero-copy">
                    A custom marketplace for games, consoles, accessories, trade-ins, drops, and community finds.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-pond btn-lg" asp-controller="Shop" asp-action="Index">Shop inventory</a>
                    <a class="btn btn-outline-pond btn-lg" href="#">Start trade-in</a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img class="hero-logo" src="~/images/brand/the-game-pond-logo.png" alt="The Game Pond mascot logo" />
            </div>
        </div>
    </div>
</section>

<section class="launch-band">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Inventory</span>
                    <h2>Real stock tracking</h2>
                    <p>Products, SKUs, conditions, quantities, and low-stock alerts will live in the custom admin dashboard.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Orders</span>
                    <h2>Simple fulfillment</h2>
                    <p>Orders move from paid to processing, packed, shipped, delivered, cancelled, or refunded.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Trade-ins</span>
                    <h2>Built for used games</h2>
                    <p>Customers submit items, staff reviews conditions, and accepted trade-ins become sellable inventory.</p>
                </div>
            </div>
        </div>
    </div>
</section>
