@{
    ViewData["Title"] = "Collect. Play. Repeat.";
    ViewData["MetaDescription"] = "The Game Pond is a custom marketplace for games, consoles, trading cards, accessories, collectibles, and community trade-ins.";
    ViewData["CanonicalUrl"] = Url.Action("Index", "Home", null, Context.Request.Scheme);
    ViewData["OgImage"] = Url.Content("~/images/brand/the-game-pond-logo.png");
}

<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <p class="eyebrow">Retro Games | Collectibles | Anime Finds</p>
            <h1>The Game Pond</h1>
            <p class="hero-copy">
                Level up your collection with curated games, consoles, cards, figures, accessories, and local trade-in finds.
            </p>
            <div class="hero-actions">
                <a class="btn btn-pond btn-lg" asp-controller="Shop" asp-action="Index">Shop inventory</a>
                <a class="btn btn-outline-pond btn-lg" asp-controller="TradeIns" asp-action="Create">Start trade-in</a>
            </div>
            <div class="hero-badges" aria-label="Store highlights">
                <span>Good games</span>
                <span>Great finds</span>
                <span>Happy pond</span>
            </div>
        </div>
        <img class="hero-mark" src="~/images/brand/the-game-pond-logo.png" alt="" aria-hidden="true" />
    </div>
</section>

<section class="launch-band">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Now stocking</p>
            <h2>Fresh finds for every kind of player</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Retro</span>
                    <h2>Games and consoles</h2>
                    <p>Browse classics, handhelds, controllers, accessories, and condition-checked hardware ready for a new shelf.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Collect</span>
                    <h2>Cards and collectibles</h2>
                    <p>Find trading cards, figures, boxed sets, and small-batch drops with a clean checkout path.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-tile">
                    <span class="feature-label">Trade</span>
                    <h2>Turn extras into credit</h2>
                    <p>Send your list, get a staff review, and bring in approved games or collectibles for final inspection.</p>
                </div>
            </div>
        </div>
    </div>
</section>
