@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-shell">
    <div class="container">
        <div class="admin-heading">
            <div>
                <p class="eyebrow">The Game Pond operations</p>
                <h1>Admin Dashboard</h1>
            </div>
            <span class="admin-status">Sprint 1 catalog</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Inventory</span>
                    <h2>Products and stock</h2>
                    <p>Manage catalog records, SKU and barcode fields, product images, stock counts, and low-stock thresholds.</p>
                    <a class="tile-link" asp-controller="AdminProducts" asp-action="Index">Open products</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Categories</span>
                    <h2>Shop organization</h2>
                    <p>Maintain the category list used by admin product entry and future storefront filters.</p>
                    <a class="tile-link" asp-controller="AdminCategories" asp-action="Index">Open categories</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Orders</span>
                    <h2>Fulfillment queue</h2>
                    <p>Prepared for paid, processing, packed, shipped, cancelled, and refunded states in Sprint 4.</p>
                </div>
            </div>
        </div>

        @if (Model.LowStockProducts.Count > 0)
        {
            <div class="admin-alert-panel">
                <div>
                    <span class="feature-label">Low stock</span>
                    <h2>Needs attention</h2>
                </div>
                <div class="low-stock-list">
                    @foreach (var product in Model.LowStockProducts)
                    {
                        <a asp-controller="AdminProducts" asp-action="Stock" asp-route-id="@product.Id">
                            <span>@product.Name</span>
                            <strong>@(product.InventoryItem?.QuantityOnHand ?? 0)</strong>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</section>
