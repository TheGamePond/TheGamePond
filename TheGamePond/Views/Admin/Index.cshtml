@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-shell">
    <div class="container">
        <div class="admin-heading">
            <div>
                <p class="eyebrow">The Game Pond operations</p>
                <h1>Admin Dashboard</h1>
            </div>
            <span class="admin-status">Sprint 1 inventory</span>
        </div>

        <div class="admin-metrics">
            <div class="metric-tile">
                <span>Products</span>
                <strong>@Model.ProductCount</strong>
            </div>
            <div class="metric-tile">
                <span>Active</span>
                <strong>@Model.ActiveProductCount</strong>
            </div>
            <div class="metric-tile metric-warning">
                <span>Low stock</span>
                <strong>@Model.LowStockCount</strong>
            </div>
            <div class="metric-tile">
                <span>Drafts</span>
                <strong>@Model.DraftProductCount</strong>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Inventory</span>
                    <h2>Products and stock</h2>
                    <p>Manage catalog entries, SKU, condition, quantity, and low-stock thresholds.</p>
                    <a class="tile-link" asp-controller="AdminProducts" asp-action="Index">Open products</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Orders</span>
                    <h2>Fulfillment queue</h2>
                    <p>Prepared for paid, processing, packed, shipped, cancelled, and refunded states.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-tile">
                    <span class="feature-label">Team</span>
                    <h2>Role-based access</h2>
                    <p>Owner, Admin, and Staff roles are seeded through ASP.NET Core Identity.</p>
                </div>
            </div>
        </div>

        @if (Model.LowStockProducts.Count > 0)
        {
            <div class="admin-alert-panel">
                <div>
                    <span class="feature-label">Low stock</span>
                    <h2>Needs attention</h2>
                </div>
                <div class="low-stock-list">
                    @foreach (var product in Model.LowStockProducts)
                    {
                        <a asp-controller="AdminProducts" asp-action="Stock" asp-route-id="@product.Id">
                            <span>@product.Name</span>
                            <strong>@(product.InventoryItem?.QuantityOnHand ?? 0)</strong>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</section>
